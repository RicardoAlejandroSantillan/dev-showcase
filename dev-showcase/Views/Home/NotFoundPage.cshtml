@{
    ViewData["Title"] = "Página no encontrada";
}

<div class="content-sections-container">
    <div class="content-section active notfound-container">
        
        <div class="glow-panel notfound-panel">
            <div class="glow-panel-content notfound-panel-content">
                <h1 class="notfound-title">404</h1>
                <h2 class="notfound-subtitle" data-translate="notfound.title">Ruta no encontrada</h2>
                <p class="notfound-text" data-translate="notfound.message">
                    Parece que te has perdido. La ruta o el rol al que intentas acceder no existe.
                </p>
                <p class="notfound-retry" data-translate="notfound.retry">Inténtalo de nuevo</p>
                
                <div class="roles-grid">
                    <a href="/dataScience" class="role-link-btn"><span data-translate="notfound.goToRole">ir al rol</span> <span class="accent-span" data-translate="header.roleTitle_dataScience">Ciencia de datos</span></a>
                    <a href="/DataAnalysis" class="role-link-btn"><span data-translate="notfound.goToRole">ir al rol</span> <span class="accent-span" data-translate="header.roleTitle_dataAnalyst">Análisis de Datos</span></a>
                    <a href="/DataEngineer" class="role-link-btn"><span data-translate="notfound.goToRole">ir al rol</span> <span class="accent-span" data-translate="header.roleTitle_dataEngineer">Ingeniero de Datos</span></a>
                    <a href="/webDev" class="role-link-btn"><span data-translate="notfound.goToRole">ir al rol</span> <span class="accent-span" data-translate="header.roleTitle_webDev">Desarrollador Web</span></a>
                    <a href="/fullStack" class="role-link-btn"><span data-translate="notfound.goToRole">ir al rol</span> <span class="accent-span" data-translate="header.roleTitle_fullStack">Desarrollador Full Stack</span></a>
                </div>
            </div>
        </div>
    </div>
</div>