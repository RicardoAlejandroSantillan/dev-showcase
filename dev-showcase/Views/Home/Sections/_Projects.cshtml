                    <div class="right-pnl info-pnl">
                        <h4 data-translate="projects.personal.wids2025.img1.title">Modelo XGBoost</h4>
                        <p data-translate="projects.personal.wids2025.img1.desc">Resultados del modelo y visualización de importancia de features.</p>
                    </div>
                </div>
            </div>
