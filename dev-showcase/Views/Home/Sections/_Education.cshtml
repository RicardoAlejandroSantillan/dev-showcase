<section class="section-education">

    <h2 data-translate="education.title">Educación</h2>

    <div class="filter">
        <button class="preparation-btn active" id="preparation-btn" data-translate="education.filters.preparation">
            Preparación
        </button>
        <button class="certificates-btn" id="certificates-btn" data-translate="education.filters.certificates">
            Certificados
        </button>
    </div>

    <div class="education-content">

        <div class="education-section active" id="preparation-content">

            <div class="about-me-content">
                <h3 data-translate="education.academic.title">Formación Académica</h3>
            </div>

            <div class="academic-training-card">
                <h4 data-translate="education.academic.forge.institution">Fundación Forge</h4>
                <p data-translate="education.academic.forge.program">Competencias profesionales</p>
                <p class="lenguages-tech">
                    <span data-translate="education.labels.period">Período:</span>
                    <span data-translate="education.academic.forge.period">Nov 2025 – Dic 2025</span>
                </p>
            </div>

            <div class="academic-training-card">
                <h4 data-translate="education.academic.smart.institution">Smart Teaching</h4>
                <p data-translate="education.academic.smart.program">Inglés Nivel B2 TOEFL IBT</p>
                <p class="lenguages-tech">
                    <span data-translate="education.labels.period">Período:</span>
                    <span data-translate="education.academic.smart.period">Feb 2025 – Nov 2025</span>
                </p>
            </div>

            <div class="academic-training-card">
                <h4 data-translate="education.academic.utan.institution">Universidad Tangamanga</h4>
                <p data-translate="education.academic.utan.program">Ingeniería en Tecnologías de la Información</p>
                <p class="lenguages-tech">
                    <span data-translate="education.labels.period">Período:</span>
                    <span data-translate="education.academic.utan.period">Jul 2022 – Ago 2025</span>
                </p>
            </div>

            <div class="about-me-content">
                <h3 data-translate="education.professional.title">Desarrollo Profesional</h3>
            </div>

            <div class="professional-development-card">
                <h5 data-translate="education.professional.cluster.institution">Cluster Automotriz</h5>
                <p data-translate="education.professional.cluster.program">Tendencias tecnológicas del sector automotriz</p>
            </div>

        </div>

        <div class="education-section" id="certificates-content">

            <div class="about-me-content">
                <h3 data-translate="education.certificates.forge.title">Insignias Forge</h3>
            </div>

            <div class="certificates-grid">
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/forge-compromiso.webp" alt="Compromiso con el Aprendizaje" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.forge.commitment">Compromiso con el Aprendizaje</p>
                        <span data-translate="education.certificates.forge.year">2025</span>
                    </div>
                </div>
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/forge-teamwork.webp" alt="Trabajo en Equipo" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.forge.teamwork">Trabajo en Equipo</p>
                        <span data-translate="education.certificates.forge.year">2025</span>
                    </div>
                </div>
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/forge-logro.webp" alt="Orientación al Logro" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.forge.achievement">Orientación al Logro</p>
                        <span data-translate="education.certificates.forge.year">2025</span>
                    </div>
                </div>
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/forge-liderazgo.webp" alt="Liderazgo Personal" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.forge.leadership">Liderazgo Personal</p>
                        <span data-translate="education.certificates.forge.year">2025</span>
                    </div>
                </div>
            </div>

            <div class="about-me-content">
                <h3 data-translate="education.certificates.udemy.title">Udemy</h3>
            </div>

            <div class="certificates-grid">
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/udemy-javascript.webp" alt="JavaScript Experto" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.udemy.javascript">JavaScript — Experto</p>
                        <span data-translate="education.certificates.udemy.javascriptDate">2024</span>
                    </div>
                </div>
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/udemy-python.webp" alt="Python Data Analysis" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.udemy.python">Python — Data Analysis</p>
                        <span data-translate="education.certificates.udemy.pythonDate">2025</span>
                    </div>
                </div>
            </div>

            <div class="about-me-content">
                <h3 data-translate="education.certificates.mos.title">Microsoft Office Specialist</h3>
            </div>

            <div class="certificates-grid">
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/mos-excel.webp" alt="MOS Excel 2019" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.mos.excel">Excel — MOS 2019</p>
                        <span data-translate="education.certificates.mos.year">2019</span>
                    </div>
                </div>
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/mos-word.webp" alt="MOS Word 2019" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.mos.word">Word — MOS 2019</p>
                        <span data-translate="education.certificates.mos.year">2019</span>
                    </div>
                </div>
                <div class="certificate-card">
                    <div class="certificate-image-container">
                        <img src="~/images/certificates/mos-powerpoint.webp" alt="MOS PowerPoint 2019" />
                    </div>
                    <div class="certificate-info">
                        <p data-translate="education.certificates.mos.powerpoint">PowerPoint — MOS 2019</p>
                        <span data-translate="education.certificates.mos.year">2019</span>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <div id="certificateModal" class="certificate-modal">
        <div class="modal-content">
            <button class="modal-close-btn" id="certificateModalCloseBtn" aria-label="Cerrar">
                <svg viewBox="0 0 24 24" fill="none">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <img id="certificateModalImage" src="" alt="" />
            <div class="certificate-modal-info">
                <h3 id="certificateModalTitle"></h3>
                <p id="certificateModalDate"></p>
            </div>
        </div>
    </div>

</section>