<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alex Portfolio</title>

    <link rel="icon" type="image/png" href="/images/profile/logo-32x32.png">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />

    <link href="~/css/reset.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/base.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/layout.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/header-particles.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/sidebar.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/panels-glow.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/skills.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/tech-logos.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/projects.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/charts.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/carousel.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/modal.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/map.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/responsive.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/notfound.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <aside class="sidebar" id="sidebar">
            <div class="profile-section">
                <div class="profile-image-container">
                    <img src="~/images/profile/profile.webp" alt="Ricardo Alejandro Pérez Santillán" class="profile-image">
                </div>
                <p class="sidebar-role-title" id="sidebarRoleTitle"></p>
            </div>

            <nav class="nav-menu">
                <button class="nav-button active" data-section="introduction" data-translate="navigation.introduction">Introducción</button>
                <button class="nav-button" data-section="skills" data-translate="navigation.skills">Habilidades</button>
                <button class="nav-button" data-section="projects" data-translate="navigation.projects">Proyectos & Experiencia</button>
                <button class="nav-button" data-section="education" data-translate="navigation.education">Educación</button>
            </nav>

            <div class="cv-download-section">
                <a href="~/documents/cv.pdf" download id="cvDownloadBtn" class="cv-download-btn" data-translate="navigation.downloadCV">
                    Descargar CV
                </a>
            </div>

            <div class="social-links-sidebar">
                <h3 data-translate="sidebar.socialTitle">Redes Sociales</h3>
                <div class="social-icons-container">
                    <a href="https://wa.me/4447207320" class="social-link" data-tooltip="WhatsApp" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                        </svg>
                    </a>
                    <a href="https://www.linkedin.com/in/ricardoalejandro/" class="social-link" data-tooltip="LinkedIn" target="_blank" rel="noopener noreferrer">
                        <i class="devicon-linkedin-plain"></i>
                    </a>
                    <a href="https://github.com/RicardoAlejandroSantillan" class="social-link" data-tooltip="GitHub" target="_blank" rel="noopener noreferrer">
                        <i class="devicon-github-original"></i>
                    </a>
                    <a href="https://x.com/AlexSantillanX" class="social-link" data-tooltip="X" target="_blank" rel="noopener noreferrer">
                        <i class="devicon-twitter-original"></i>
                    </a>
                </div>
            </div>
        </aside>

        <div class="main-wrapper">
            <header class="header-particles">
                <div class="particles-container">
                    @for (int i = 0; i < 20; i++)
                    {
                        <div class="particle"></div>
                    }
                </div>

                <div class="header-content">
                    <h2 data-translate="header.hello">#HOLA MUNDO</h2>
                    <h1>Soy Ricardo Alejandro Pérez Santillán</h1>
                    <p class="header-role-title" id="headerRoleTitle"></p>
                </div>
            </header>

            <main class="main-content" role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="language-selector">
        <button class="lang-btn active" data-lang="es">ES</button>
        <button class="lang-btn" data-lang="en">EN</button>
    </div>

    <button class="menu-toggle" aria-label="Toggle menu" id="menuToggle">
        <span></span><span></span><span></span>
    </button>
    <div class="menu-overlay" id="menuOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <script src="~/js/icon.js" asp-append-version="true"></script>
    <script src="~/js/main.js" asp-append-version="true"></script>
    <script src="~/js/navigation.js" asp-append-version="true"></script>
    <script src="~/js/modal-manager.js" asp-append-version="true"></script>
    <script src="~/js/glow-panels.js" asp-append-version="true"></script>
    <script src="~/js/stats-animation.js" asp-append-version="true"></script>
    <script src="~/js/charts-manager.js" asp-append-version="true"></script>
    <script src="~/js/carousel.js" asp-append-version="true"></script>
    <script src="~/js/typewriter.js" asp-append-version="true"></script>
    <script src="~/js/translation.js" asp-append-version="true"></script>
    <script src="~/js/map.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>